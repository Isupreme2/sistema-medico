# ===== Servidor =====
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ===== Base de datos (MongoDB Atlas) =====
# Reemplaza con tu connection string real en el archivo .env (NO subir .env al repo)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ehr_dev?retryWrites=true&w=majority

# DNS de respaldo (opcional). Útil si el resolver de Node falla al resolver
# el SRV de Atlas (error querySrv ECONNREFUSED). Ej: 8.8.8.8,1.1.1.1
DNS_SERVERS=

# ===== JWT =====
JWT_ACCESS_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-distinto-y-aleatorio
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ===== CORS / Frontend =====
CORS_ORIGIN=http://localhost:4200
# URL del frontend para los enlaces dentro de los correos
FRONTEND_URL=http://localhost:4200

# ===== Teleconsulta (Jitsi Meet) =====
# Dominio del servidor Jitsi para el video embebido (público por defecto)
JITSI_DOMAIN=meet.jit.si

# ===== Cookies =====
COOKIE_SECURE=false

# ===== App (para 2FA / emisor TOTP) =====
APP_NAME=Sistema Medico EHR

# ===== Email (SMTP) =====
# Si SMTP_HOST queda vacío, el mailer cae a modo "log": imprime el correo en
# consola en lugar de enviarlo (ideal para desarrollo sin servidor de correo).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sistema Médico EHR <no-reply@ehr.dev>

# ===== Recordatorios de citas (node-cron) =====
REMINDERS_ENABLED=true
# Expresión cron (por defecto cada 15 minutos)
REMINDER_CRON=*/15 * * * *
# Ventana hacia adelante (horas) para recordar citas próximas
REMINDER_WINDOW_HOURS=24

# ===== Recordatorios de tomas de medicamentos =====
# Cron del worker (por defecto cada minuto, para acertar el "en 5 min")
TOMA_REMINDER_CRON=* * * * *
# Antelación (min) con que se avisa cada toma
TOMA_LEAD_MIN=5
# Margen (min) tras la hora antes de dar una toma por omitida
TOMA_GRACE_MIN=30

# ===== WhatsApp Cloud API (Meta) =====
# Si WHATSAPP_ENABLED=false o falta token/phone id, cae a modo "log"
# (imprime el mensaje en consola) y funciona sin credenciales reales.
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v21.0
# Plantilla pre-aprobada para el recordatorio (obligatoria fuera de la ventana de 24 h)
WHATSAPP_TEMPLATE_TOMA=
# Código de país que se antepone a móviles locales sin prefijo (Perú = 51)
WHATSAPP_DEFAULT_COUNTRY=51
# Vigencia del enlace firmado que abre la receta desde el chat
RECETA_LINK_EXPIRES=7d
